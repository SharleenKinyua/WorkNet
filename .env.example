# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Google Gemini API Key (REQUIRED)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Django Settings (Optional - already configured in settings.py)
# DJANGO_DEBUG=True
# DJANGO_SECRET_KEY=your-django-secret-key

# Database Configuration (Optional - SQLite used by default)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# For Production PostgreSQL (if needed):
# DATABASES_ENGINE=django.db.backends.postgresql
# DATABASES_NAME=worknet_db
# DATABASES_USER=postgres
# DATABASES_PASSWORD=your_db_password
# DATABASES_HOST=localhost
# DATABASES_PORT=5432
